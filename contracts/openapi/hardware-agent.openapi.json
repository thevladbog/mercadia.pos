{
  "components": {
    "schemas": {
      "Problem": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "code"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Local device API for fiscal devices, payment terminals, scanners, scales, drawers, printers, MSR, and iButton readers.",
    "title": "Mercadia Hardware Agent",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "service": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "time": {
                      "format": "date-time",
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "service",
                    "status",
                    "version",
                    "time"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is alive"
          }
        },
        "summary": "Get service health",
        "tags": [
          "system"
        ]
      }
    },
    "/readyz": {
      "get": {
        "operationId": "getReadiness",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "service": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "time": {
                      "format": "date-time",
                      "type": "string"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "service",
                    "status",
                    "version",
                    "time"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Service is ready"
          }
        },
        "summary": "Get service readiness",
        "tags": [
          "system"
        ]
      }
    },
    "/v1/devices": {
      "get": {
        "operationId": "listDevices",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "kind": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "kind",
                      "status"
                    ],
                    "type": "object"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Local device list"
          }
        },
        "summary": "List local devices",
        "tags": [
          "hardware"
        ]
      }
    },
    "/v1/devices/{deviceId}/commands": {
      "post": {
        "operationId": "sendDeviceCommand",
        "parameters": [
          {
            "in": "path",
            "name": "deviceId",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Unique key used to make command execution idempotent.",
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "minLength": 8,
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "deviceId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "deviceId",
                    "status"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Device command accepted"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "code": {
                      "type": "string"
                    },
                    "detail": {
                      "type": "string"
                    },
                    "status": {
                      "type": "integer"
                    },
                    "title": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "title",
                    "status",
                    "code"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Invalid device command"
          }
        },
        "summary": "Send command to a local device",
        "tags": [
          "hardware"
        ]
      }
    },
    "/v1/hardware/status": {
      "get": {
        "operationId": "getHardwareAgentStatus",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "generatedAt": {
                      "format": "date-time",
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "terminalId": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "terminalId",
                    "status",
                    "generatedAt"
                  ],
                  "type": "object"
                }
              }
            },
            "description": "Hardware Agent status"
          }
        },
        "summary": "Get Hardware Agent status",
        "tags": [
          "hardware"
        ]
      }
    }
  }
}
