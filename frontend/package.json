{
  "name": "@mercadia/frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11.5.2"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "orval:central": "orval --config packages/api-clients/central/orval.config.ts",
    "orval:hardware-agent": "orval --config packages/api-clients/hardware-agent/orval.config.ts",
    "orval:store-edge": "orval --config packages/api-clients/store-edge/orval.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook:ui": "pnpm --filter @mercadia/ui storybook",
    "build-storybook:ui": "pnpm --filter @mercadia/ui build-storybook",
    "verify": "pnpm orval:central && pnpm orval:store-edge && pnpm orval:hardware-agent && pnpm typecheck && pnpm lint && pnpm format:check && pnpm --filter @mercadia/ui test && pnpm --filter admin-web build && pnpm --filter pos-terminal typecheck && pnpm --filter senior-cashier-terminal typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "orval": "^8.19.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
